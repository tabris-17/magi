.DS_Store

# Python bytecode cache
__pycache__/
*.pyc

# Virtualenvs
.venv/
venv/

# Deploy: machine-specific config (never commit / never rsync)
deploy/config.sh

# Runtime data root (config.DATA_DIR / BETELGEUSE_DATA_DIR default = <repo>/data):
